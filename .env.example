# .env
# Data Lie Detector - OAuth Credentials
# Do not commit this file to version control if you rename it to .env and add real secrets.

# ==========================================
# GOOGLE OAUTH
# Get these at: https://console.cloud.google.com/apis/credentials
# ==========================================
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==========================================
# MICROSOFT OAUTH
# Get these at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# ==========================================
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"
MICROSOFT_TENANT_ID="common" # Use 'common' for multi-tenant (personal + work accounts)

# ==========================================
# REDIRECT URI
# Must match exactly what is registered in the developer consoles.
# ==========================================
REDIRECT_URI="http://localhost:8000/?app=true"
STREAMLIT_URL="http://localhost:8000/?app=true"
